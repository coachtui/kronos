# Copy to .env and fill in. NEVER commit .env or hardcode keys.

# --- Anthropic (Milestone 3: script generation) ---
ANTHROPIC_API_KEY=
# Configurable Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# --- ElevenLabs (Milestone 4: voiceover + captions) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Optional: eleven_turbo_v2_5 (cheaper, default) | eleven_multilingual_v2 (best quality)
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- Hugging Face cache location (optional; defaults to ~/.cache/huggingface) ---
HF_HOME=

# --- Kronos model (Milestone 1) ---
KRONOS_MODEL_NAME=NeoQuasar/Kronos-mini
KRONOS_TOKENIZER_NAME=NeoQuasar/Kronos-Tokenizer-2k

# --- Data provider abstraction ---
# Supported now: yfinance, mock. Later: polygon, tiingo, alphavantage, fmp
DATA_PROVIDER=yfinance

# --- News / catalysts (free key from finnhub.io) ---
# Powers the "why" behind market moves in [MACRO BACKDROP]. Earnings dates use
# yfinance (no key needed).
FINNHUB_API_KEY=
